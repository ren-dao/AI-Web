DATABASE_URL="file:./dev.db"

# Comma-separated tunnel domain patterns for accessing the dev server via
# ngrok / frp / Cloudflare Tunnel / localtunnel / etc.
#
# Wildcard rules:
#   "*"   - matches exactly one DNS label (e.g., *.ngrok.io matches abc.ngrok.io)
#   "**"  - matches zero or more DNS labels (e.g., **.ngrok-free.app matches
#           abc.ngrok-free.app and x.y.ngrok-free.app)
#
# Leave empty for default (localhost only).
#
# Examples:
#   ALLOWED_DEV_ORIGINS=*.ngrok.io,*.ngrok-free.app
#   ALLOWED_DEV_ORIGINS=**.lhr.life
#   ALLOWED_DEV_ORIGINS=my-subdomain.example.com
ALLOWED_DEV_ORIGINS=
