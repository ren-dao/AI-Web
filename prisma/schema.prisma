generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SideHustle {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  category        String
  description     String
  fullDescription String
  difficulty      String
  timeInvestment  String
  incomeMin       Int
  incomeMax       Int
  requiredSkills  String    // JSON array
  toolsResources  String    // JSON array
  startupCost     String
  stepsToStart    String    // JSON array
  pros            String    // JSON array
  cons            String    // JSON array
  tipsForSuccess  String    // JSON array
  resourceLinks   String    // JSON array [{title, url}]
  coverImage      String?

  viewCount       Int       @default(0)
  averageRating   Float     @default(0)
  ratingCount     Int       @default(0)
  commentCount    Int       @default(0)
  isApproved      Boolean   @default(true)
  isFeatured      Boolean   @default(false)

  submitterName   String
  submitterEmail  String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  comments        Comment[]
  ratings         Rating[]

  @@index([category])
  @@index([difficulty])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([averageRating])
}

model Comment {
  id            String      @id @default(cuid())
  content       String
  authorName    String
  authorEmail   String?

  sideHustleId  String
  sideHustle    SideHustle  @relation(fields: [sideHustleId], references: [id], onDelete: Cascade)

  parentId      String?
  parent        Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]   @relation("CommentReplies")

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([sideHustleId])
  @@index([parentId])
}

model Rating {
  id            String      @id @default(cuid())
  value         Int
  authorName    String
  authorEmail   String?

  sideHustleId  String
  sideHustle    SideHustle  @relation(fields: [sideHustleId], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())

  @@unique([sideHustleId, authorEmail])
  @@index([sideHustleId])
}
